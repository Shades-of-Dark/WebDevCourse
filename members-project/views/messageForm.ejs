<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Message — The Clubhouse</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<nav>
    <a class="nav-brand" href="/">The Clubhouse</a>
    <div class="nav-links">
        <a href="/">Back to Feed</a>
    </div>
</nav>

<div class="page-centered">
    <div class="form-card">
        <h1 class="form-title">New Message</h1>
        <p class="page-subtitle">Share something with the club.</p>

        <form method="POST" action="/new-message">
            <div class="form-group">
                <label for="title">Title</label>
                <input type="text" name="title" id="title" placeholder="Give your message a title..." required>
            </div>
            <div class="form-group">
                <label for="message">Message</label>
                <textarea name="message" id="message" placeholder="What's on your mind?" required></textarea>
            </div>
            <button class="btn btn-primary btn-full" type="submit">Post Message</button>
        </form>
    </div>
</div>

</body>
</html>
